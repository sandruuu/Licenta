# ============================================================
#  ZTNA Environment Variables
#  Used by both cloud (native) and docker-compose
# ============================================================

# ── Shared Secrets ──
JWT_SECRET=ztna-jwt-secret-change-in-production-2024
SESSION_STORE_TOKEN=ztna-session-store-token-change-in-production-2024

# ── Cloud Admin (created on first run) ──
ADMIN_USER=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@ztna.local

# ── RDP Desktop ──
RDP_USER=admin
RDP_PASSWORD=admin

# ── SSH Server ──
SSH_USER=admin
SSH_PASSWORD=admin
