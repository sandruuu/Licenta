# ========================================
# ZTNA Lab - Environment Variables
# ========================================
# Copy this file to .env and fill in secure values:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -hex 32
# ========================================

# JWT signing secret for the cloud IdP (min 32 chars)
JWT_SECRET=

# Inter-service auth token for session store (min 32 chars)
SESSION_STORE_TOKEN=

# Gateway admin panel credentials
ADMIN_EMAIL=admin@gateway.local
ADMIN_PASSWORD=

# RDP test desktop credentials
RDP_USER=testuser
RDP_PASSWORD=

# SSH test server credentials
SSH_USER=testuser
SSH_PASSWORD=
